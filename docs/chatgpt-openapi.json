  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "Value must match CHATGPT_ACTION_API_KEY"
      }
    },
    "responses": {
      "UnauthorizedJson": {
        "description": "Unauthorized response",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/UnauthorizedResponse" }
          }
        }
      }
    },
    "schemas": {
      "AnyObject": {
        "type": "object",
        "additionalProperties": true
      },
      "UnauthorizedResponse": {
        "type": "object",
        "required": ["success", "error", "route", "timestamp"],
        "properties": {
          "success": { "type": "boolean" },
          "error": { "type": "string" },
          "route": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      },
      "CreateInternalTaskRequest": {
        "type": "object",
        "required": ["entityType", "entityId", "taskType"],
        "properties": {
          "entityType": { "type": "string" },
          "entityId": { "type": "string" },
          "taskType": { "type": "string" },
          "note": { "type": "string" },
          "priority": { "type": "string" }
        }
      },
      "TaskActionRequest": {
        "type": "object",
        "required": ["taskId"],
        "properties": {
          "taskId": { "type": "string" }
        }
      },
      "DraftRequest": {
        "type": "object",
        "properties": {
          "orderId": { "type": "string" },
          "customerName": { "type": "string" },
          "note": { "type": "string" }
        }
      },
      "RunDecisionEngineRequest": {
        "type": "object",
        "additionalProperties": true
      }
    }
  }
}
