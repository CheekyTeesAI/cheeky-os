<?xml version="1.0" encoding="utf-8"?>
<Attributes>
  <!-- Order lookup -->
  <Attribute LogicalName="crb_orderid" Type="Lookup" Targets="crb_orders" DisplayName="Order" />
  <!-- Product Name -->
  <Attribute LogicalName="crb_productname" Type="String" MaxLength="200" DisplayName="Product Name" />
  <!-- Garment Color -->
  <Attribute LogicalName="crb_garmentcolor" Type="String" MaxLength="100" DisplayName="Garment Color" />
  <!-- Sizes JSON -->
  <Attribute LogicalName="crb_sizesjson" Type="Memo" DisplayName="Sizes JSON" Description="JSON mapping of size to quantity" />
  <!-- Quantity -->
  <Attribute LogicalName="crb_quantity" Type="Integer" DisplayName="Quantity" />
  <!-- Artwork URL -->
  <Attribute LogicalName="crb_artworkurl" Type="URL" DisplayName="Artwork URL" />
  <!-- Print Method choice -->
  <Attribute LogicalName="crb_printmethod" Type="Choice" DisplayName="Print Method">
    <ChoiceOptions>
      <Option>DTG</Option>
      <Option>Screen Print</Option>
      <Option>DTF</Option>
      <Option>Embroidery</Option>
    </ChoiceOptions>
  </Attribute>
</Attributes>
