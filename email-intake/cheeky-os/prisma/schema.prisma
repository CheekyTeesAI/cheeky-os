generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma-marketing"
}

datasource db {
  provider = "sqlite"
  url      = env("CHEEKY_MARKETING_DATABASE_URL")
}

model Customer {
  id               String   @id @default(cuid())
  squareCustomerId String   @unique
  name             String?
  email            String?
  phone            String?
  lastOrderDate    DateTime?
  totalSpent       Float    @default(0)
  createdAt        DateTime @default(now())
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  source    String   @default("google_ads")
  createdAt DateTime @default(now())
}

model CampaignLog {
  id        String   @id @default(cuid())
  type      String
  status    String
  recipient String
  createdAt DateTime @default(now())
}

/// Bundle 3 — notebook / quick-capture production orders (not Square orders).
model CaptureOrder {
  id              String        @id @default(cuid())
  customerName    String
  quantity        Int           @default(0)
  product         String        @default("")
  printType       String        @default("")
  dueDate         String        @default("")
  status          String        @default("INTAKE")
  paymentStatus   String        @default("")
  depositRequired Boolean       @default(true)
  depositReceived Boolean       @default(false)
  balanceDue      Float         @default(0)
  paymentNotes    String        @default("")
  memoryJson      String        @default("{}")
  createdAt       DateTime      @default(now())
  tasks           CaptureTask[]
}

model CaptureTask {
  id        String       @id @default(cuid())
  orderId   String
  order     CaptureOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  title     String
  status    String       @default("PENDING")
  createdAt DateTime     @default(now())

  @@index([orderId])
}
