{
  "name": "cheeky-os",
  "version": "4.3.0",
  "engines": {
    "node": "18.x"
  },
  "scripts": {
    "start": "node -r ./scripts/cheekyOsLoadEnv.js cheeky-os/server.js",
    "test:dashboard": "node -r ./scripts/cheekyOsLoadEnv.js ./scripts/test-dashboard-data.js",
    "smoke": "node scripts/smoke.js",
    "_postinstall": "prisma generate --schema prisma-foundation/schema.prisma && prisma generate",
    "postinstall:prisma": "prisma generate --schema prisma-foundation/schema.prisma && prisma generate",
    "db:foundation:migrate": "prisma migrate dev --schema prisma-foundation/schema.prisma",
    "bootstrap": "node social/scripts/bootstrap.js",
    "dev": "node --import tsx ./src/api/voice.run.ts",
    "reset": "taskkill /F /IM node.exe >nul 2>&1 || exit 0",
    "dev:clean": "npm run reset && npm run dev",
    "dev:watch": "tsx watch src/api/voice.run.ts",
    "dev:social": "node social/scripts/bootstrap.js && npx --yes nodemon@3.1.9 server.js",
    "dev:tsx": "tsx src/api/voice.run.ts",
    "dev:ts-node": "ts-node --transpile-only src/api/voice.run.ts",
    "build": "tsc",
    "prisma:clean": "node scripts/clean-prisma-client.js",
    "prisma:generate": "node scripts/prisma-generate-retry.js",
    "seed:stages:csv": "node scripts/emit-stage-seed-csv.js",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck",
    "social:verify": "node social/scripts/verify-batch.js && node social/scripts/verify-routes.js",
    "smoke:test": "node scripts/smoke-test.js",
    "smoke:activation:v7": "node -r ./scripts/cheekyOsLoadEnv.js ./cheeky-os/scripts/live-activation-v7-smoke.js",
    "release:verify": "node scripts/smoke-test.js",
    "order:audit": "node scripts/order-state-audit.js",
    "money:report": "node scripts/money-path-report.js",
    "order:reconcile": "node scripts/order-payment-reconcile.js",
    "money:export": "node scripts/money-path-export.js",
    "intake-e2e": "node -r ./scripts/cheekyOsLoadEnv.js ./scripts/cheekyOsIntakeE2eProbe.js",
    "operator": "node scripts/operator.js",
    "daily:status": "node scripts/daily-status.js",
    "daily:incidents": "node scripts/daily-incident-summary.js",
    "batch:review": "node scripts/batch-review.js",
    "ops:digest": "node scripts/overnight-ops-digest.js",
    "follow-up:targets": "node scripts/follow-up-targets.js",
    "reactivation:drafts": "node scripts/reactivation-drafts.js",
    "vip:recovery": "node scripts/vip-recovery.js",
    "vip:drafts": "node scripts/vip-recovery-drafts.js",
    "quote:acceleration": "node scripts/quote-acceleration.js",
    "revenue:center": "node scripts/revenue-command-center.js",
    "send-queue": "node scripts/send-queue.js",
    "guarded-send": "node scripts/guarded-send.js",
    "webhook:inspect": "node scripts/webhook-replay-inspect.js"
  },
  "dependencies": {
    "@azure/identity": "^4.13.1",
    "@azure/msal-node": "^2.16.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "6.3.0",
    "axios": "^1.6.0",
    "clipboardy": "^2.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^7.0.0",
    "form-data": "^4.0.0",
    "google-ads": "npm:google-ads-api@^23.0.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^3.2.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.8",
    "openai": "^6.33.0",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.15.2",
    "resend": "^4.8.0",
    "square": "^35.0.0",
    "twilio": "^5.13.1",
    "winston": "^3.10.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.14",
    "prisma": "6.3.0",
    "ts-node": "^10.9.1",
    "tsx": "^4.19.2",
    "typescript": "^5.3.0"
  }
}
