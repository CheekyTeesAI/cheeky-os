DATABASE_URL=
# Cheeky OS foundation (SQLite) — job persistence, tasks, art files, event log.
# Resolves relative to prisma-foundation/ if you use file:./data/foundation.db in schema runs;
# runtime default: prisma-foundation/data/foundation.db (see src/services/foundationPrisma.js)
FOUNDATION_DATABASE_URL=

PORT=3000
# Local override when PORT is taken (cheeky-os/server.js)
CHEEKY_OS_PORT=

# AI — cheeky-os readiness logs model; default gpt-4o-mini if unset
# Get key: https://platform.openai.com/api-keys
# Missing behavior: AI extractor auto-falls back to openaiMock + rule parser
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Get token/location: Square Developer Dashboard
# Missing behavior: collections/invoice logic auto-falls back to squareMock
SQUARE_ACCESS_TOKEN=REPLACE_ME
SQUARE_LOCATION_ID=REPLACE_ME
# Optional: sandbox | production (otherwise inferred from token)
SQUARE_ENVIRONMENT=

# Square webhooks — https://developer.squareup.com/docs/webhooks/step3validate
# When set, POST /api/square/webhook and POST /webhooks/square/webhook verify
# x-square-hmacsha256-signature using notification URL + body.
SQUARE_WEBHOOK_SIGNATURE_KEY=
# Full URL of this webhook in Square (no query string). Use when Host/proto headers differ from the subscription URL.
SQUARE_WEBHOOK_NOTIFICATION_URL=
# Local/dev only: set true to skip verification (never in production).
SQUARE_WEBHOOK_SIGNATURE_SKIP_VERIFY=false

# Power Automate — unified command layer (Dataverse / Outlook)
POWER_AUTOMATE_DATAVERSE_WEBHOOK=
POWER_AUTOMATE_OUTLOOK_WEBHOOK=
DEFAULT_FROM_EMAIL=customer.service@cheekyteesllc.com
# Resend — command layer live email (lib/integrations/outlook.js)
# Get key: https://resend.com/api-keys
# Missing behavior: send pipeline should fall back to resendMock
RESEND_API_KEY=REPLACE_ME
EMAIL_API_KEY=
# Sender identity for Resend
RESEND_FROM=
# Bullseye — recipient for work orders from POST /command ("send work order to Bullseye…")
BULLSEYE_EMAIL=
# Vendor PO outbound (optional; missing = preview works, send blocked until set)
CAROLINA_MADE_EMAIL=
SS_EMAIL=
SANMAR_EMAIL=
# Pipe-separated: address|city|state|zip — optional; safe placeholder if unset
BULLSEYE_SHIP_ADDRESS=
BULLSEYE_SHIP_NAME=Bullseye
# Optional: PDF output directory (default: <os.tmpdir>/workorders, e.g. /tmp/workorders on Render)
WORK_ORDER_DIR=
# Bullseye vendor PDF autofill (pdf-lib) — paths relative to repo root when unset
BULLSEYE_TEMPLATE_PATH=
BULLSEYE_FIELD_MAP_PATH=
# 0 = use legacy pdfkit layout instead of filling the vendor template
WORK_ORDER_USE_TEMPLATE=1
# 1 = if template fill throws, fall back to legacy PDF (default 0 = fail loud)
WORK_ORDER_TEMPLATE_FALLBACK=0
# When bulk order has only MIXED sizes, put total in this size column (S|M|L|XL|2XL|3XL)
WORK_ORDER_MIXED_SIZE_KEY=M
# Art uploads for work orders: attach art reads uploads/<uploadJobId|foundationJobKey>/
UPLOADS_DIR=
# 1 = flatten AcroForm after fill (some vendor PDFs break; leave unset unless needed)
WORK_ORDER_FLATTEN_PDF=
CHEEKY_ADDRESS=104 Trade Street, Fountain Inn SC
CHEEKY_CONTACT_NAME=Patrick
CHEEKY_CONTACT_EMAIL=
# Must match the key you pass as ?apikey= or ?apiKey= (no quotes needed)
API_KEY=cheeky-secret-123
USE_MOCK=true
SYSTEM_DISABLED=false

# Outlook / Microsoft 365 (outreach delivery)
# Missing behavior: mailers remain in mock/stub mode
OUTREACH_EMAIL=
OUTREACH_PASSWORD=
AUTO_SEND=true
DRY_RUN=true
MAX_SEND=2
AUTO_APPROVE=false
AUTO_RUN_COMMAND=false
REACTIVATION_AUTO_APPROVE=false
AVG_ORDER_VALUE=350

CHEEKY_BIZ_NAME=Cheeky Tees
CHEEKY_PHONE=864-498-3475
CHEEKY_PROMO=

# Twilio SMS follow-up
# Get creds: https://console.twilio.com/
# Missing behavior: SMS pipeline should fall back to twilioMock
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Microsoft Graph / OneDrive storage fallback
# Get token via Azure app / delegated auth flow
# Missing behavior: storageService falls back to local JSON + onedriveMock
MSGRAPH_ACCESS_TOKEN=
ONEDRIVE_AUDIT_ITEM_ID=

# Optional: after boot, POST /revenue/command (full founder command cycle). Default off.
AUTO_DAILY_RUN=false

# 24h loop: POST /outreach/daily-run, /outreach/followup-run, then /outreach/send-approved if AUTO_SEND=true. Default off.
DAILY_SCHEDULER=false

# voice.run.ts — command-layer scheduler (hourly event engine + daily war room email). Default off.
ENABLE_SCHEDULER=false

# cheeky-os — when true, warn on production-like deploy without Square token (does not exit)
STRICT_ENV=false

# Optional digest hooks (readiness only unless your routes use them)
DAILY_DIGEST_ENABLED=false
DAILY_DIGEST_TO=
DAILY_DIGEST_HOUR=9

# v7.3 Full Auto Mode (single loop via automationRunner)
FULL_AUTO_ENABLED=true
FULL_AUTO_INTERVAL_MS=300000
FULL_AUTO_MODE=SAFE

# --- GPT Actions (ChatGPT Custom Action) — set in hosting dashboard for production, not committed ---
# Strong random secret; never use replace_me, test, or short placeholders (see src/services/envValidation.js)
CHATGPT_ACTION_API_KEY=
# Public HTTPS origin of this API (no trailing slash). Not your-production-domain placeholder.
PUBLIC_BASE_URL=
# Local smoke tests only; defaults in scripts if unset
# SELFTEST_BASE_URL=http://127.0.0.1:3000
