PORT=3000

OPENAI_API_KEY=
SQUARE_ACCESS_TOKEN=REPLACE_ME
SQUARE_LOCATION_ID=REPLACE_ME
# Optional: sandbox | production (otherwise inferred from token)
SQUARE_ENVIRONMENT=

# Power Automate — unified command layer (Dataverse / Outlook)
POWER_AUTOMATE_DATAVERSE_WEBHOOK=
POWER_AUTOMATE_OUTLOOK_WEBHOOK=
DEFAULT_FROM_EMAIL=customer.service@cheekyteesllc.com
# Resend — command layer live email (lib/integrations/outlook.js)
RESEND_API_KEY=REPLACE_ME
EMAIL_API_KEY=
# Must match the key you pass as ?apikey= or ?apiKey= (no quotes needed)
API_KEY=cheeky-secret-123
USE_MOCK=true
SYSTEM_DISABLED=false

# Supabase / Postgres (Prisma)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public

# Outlook / Microsoft 365 (outreach delivery)
OUTREACH_EMAIL=
OUTREACH_PASSWORD=
AUTO_SEND=true
DRY_RUN=true
MAX_SEND=2
AUTO_APPROVE=false
AUTO_RUN_COMMAND=false
REACTIVATION_AUTO_APPROVE=false
AVG_ORDER_VALUE=350

CHEEKY_BIZ_NAME=Cheeky Tees
CHEEKY_PHONE=864-498-3475
CHEEKY_PROMO=

# Optional: after boot, POST /revenue/command (full founder command cycle). Default off.
AUTO_DAILY_RUN=false

# 24h loop: POST /outreach/daily-run, /outreach/followup-run, then /outreach/send-approved if AUTO_SEND=true. Default off.
DAILY_SCHEDULER=false
