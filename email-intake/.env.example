# ── Cheeky Tees / Cheeky OS — Environment Variables ──────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to source control — only this .env.example.

# ── Dataverse Connection ─────────────────────────────────────────────────────
# Option A: Pre-obtained bearer token (quickest for testing)
# DATAVERSE_TOKEN=

# Option B: Client credentials (production)
DATAVERSE_URL=https://YOUR_ORG.crm.dynamics.com
DATAVERSE_TENANT_ID=
DATAVERSE_CLIENT_ID=
DATAVERSE_CLIENT_SECRET=

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Microsoft Graph API (Email Poller) ───────────────────────────────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
OUTLOOK_USER_EMAIL=

# ── Webhook Server ───────────────────────────────────────────────────────────
PORT=3000
WEBHOOK_SECRET=

# ── Square Integration ───────────────────────────────────────────────────────
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_ENVIRONMENT=sandbox

# ── Health Monitor / Teams Alerts ────────────────────────────────────────────
TEAMS_WEBHOOK_URL=
