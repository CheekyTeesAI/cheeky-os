# ── Cheeky Tees / Cheeky OS — Environment Variables ──────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to source control — only this .env.example.

# ── Dataverse Connection ─────────────────────────────────────────────────────
# Option A: Pre-obtained bearer token (quickest for testing)
# DATAVERSE_TOKEN=

# Option B: Client credentials (production)
DATAVERSE_URL=https://YOUR_ORG.crm.dynamics.com
DATAVERSE_TENANT_ID=
DATAVERSE_CLIENT_ID=
DATAVERSE_CLIENT_SECRET=

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Microsoft Graph API (Email Poller) ───────────────────────────────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
OUTLOOK_USER_EMAIL=

# ── Webhook Server (Express: intake + Cheeky OS at /cheeky) ──────────────────
# BASE_URL should match where webhook/server is listening.
PORT=3000
WEBHOOK_SECRET=
BASE_URL=http://localhost:3000

# ── Orders Export API (same local runtime default) ───────────────────────────
EXPORT_PORT=3000
API_BASE_URL=http://localhost:3000

# ── Square Integration ───────────────────────────────────────────────────────
SQUARE_ACCESS_TOKEN=your_token_here
SQUARE_LOCATION_ID=your_location_id
SQUARE_ENVIRONMENT=sandbox

# ── Health Monitor / Teams Alerts ────────────────────────────────────────────
TEAMS_WEBHOOK_URL=
