# ── Cheeky OS / CheekyAPI — Root .gitignore ──────────────────────────────────

# ── Secrets ──────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
local.settings.json
deployment-config.json
.dv_token.tmp

# ── Node.js ──────────────────────────────────────────────────────────────────
node_modules/
# Prisma secondary client (foundation SQLite) — regenerated via postinstall
src/generated/

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
**/logs/
*.log
!email-intake/scripts/*.log

# ── Bridge runtime output ────────────────────────────────────────────────────
bridge/tickets/
bridge/errors/
**/bridge/tickets/
**/bridge/errors/

# ── .NET build output ────────────────────────────────────────────────────────
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
artifacts/

# ── Visual Studio ────────────────────────────────────────────────────────────
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs

# ── Test Results ─────────────────────────────────────────────────────────────
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.VisualState.xml
TestResult.xml

# ── NuGet ────────────────────────────────────────────────────────────────────
*.nupkg
**/packages/*
!**/packages/build/

# ── OS files ─────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
